# Скопируй в .env и впиши реальные креды. .env НЕ коммитится (см. .gitignore).

# --- Impala (обязательно для live-сборки) ---
IMPALA_PRIMARY_HOST=bdas-worker-08.bdpak.telecom.kz
IMPALA_BACKUP_HOST=bdas-utility-01.bdpak.telecom.kz
IMPALA_PORT=21050
IMPALA_DATABASE=drb
IMPALA_USER=
IMPALA_PASSWORD=
IMPALA_USE_SSL=true
IMPALA_AUTH_MECHANISM=PLAIN
IMPALA_TIMEOUT=60

# --- Postgre (опционально; оставь пустым, если не используешь) ---
PG_HOST=
PG_PORT=5432
PG_DBNAME=
PG_USER=
PG_PASSWORD=
PG_SSLMODE=prefer
